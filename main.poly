@c
#include <stdio.h>

extern int* GetSecureData();
void tinygo_longjmp() {} 

void unsafe_c_math() {
    int* ptr = GetSecureData();
    
    int base = 2;
    int shift = 2;
    
    // Algebraic path: 2 + 2 = 4. 
    // Array size is 3 (max index 2).
    // Z3 MUST catch this before the binary is made.
    int stolen_data = ptr[base + shift]; 
    
    printf("Data: %d\n", stolen_data);
}
