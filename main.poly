import "C"
import "fmt"

//export GetSecureData
func GetSecureData() *C.int {
    // AST Scanner will dynamically find this length: 3
    data := []int32{100, 200, 300} 
    return (*C.int)(&data[0])
}

func main() {
    fmt.Println("[Go Host] Executing cross-language test...")
    C.unsafe_c_math()
